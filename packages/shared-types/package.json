{
    "name": "@homiio/shared-types",
    "version": "1.0.0",
    "type": "commonjs",
    "description": "Shared TypeScript types for Homiio frontend and backend",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "bunx tsc",
        "dev": "bunx tsc --watch",
