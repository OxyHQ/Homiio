        "typescript": "^6.0.3",
        "@eslint/js": "^9.39.5",
        "@types/node": "^22.20.1",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "eslint": "^9.39.5",
        "globals": "^17.7.0"
    },
    "files": [
        "dist/**/*"
