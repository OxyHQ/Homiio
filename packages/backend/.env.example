# =============================================================================
# Homiio Backend (@homiio/backend) — runtime environment variables
# =============================================================================
# Copy to `.env` and fill in real values for local dev. In production (AWS),
# inject these via the orchestrator's secret store / task definition.
# Values shown after `=` are illustrative defaults/format ONLY — never commit
# real secrets. Variables marked [SECRET] must come from a secrets manager.
# Variables with a sensible code default are marked [optional].
# =============================================================================

# --- Core runtime -----------------------------------------------------------
NODE_ENV=production
# Port the HTTP server listens on (defaults to 4000 in config.ts).
PORT=4000
# Public, externally-reachable base URL of THIS backend (no trailing slash).
# Used to build absolute URLs the client fetches directly (e.g. self-hosted
# image store at /api/images/file/*). [optional]
PUBLIC_API_URL=https://api.homiio.com
# Public base URL of the Homiio web/app frontend — source for server-built deep
# links and Stripe redirect URLs. [optional]
FRONTEND_URL=https://homiio.com

# --- Database (MongoDB) -----------------------------------------------------
# Primary connection string. DATABASE_URL is an accepted fallback. [SECRET]
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/homiio
# DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/homiio   # [SECRET] fallback for MONGODB_URI

# --- Oxy ecosystem integration ----------------------------------------------
# Base URL of the Oxy API (used by @oxyhq/core in production). [optional]
OXY_API_URL=https://api.oxy.so
# Base URL for internal service-to-service calls, if used. [optional]
INTERNAL_API_BASE_URL=https://api.oxy.so
# Generic API base URL consumed by some clients. [optional]
API_URL=https://api.homiio.com

# --- OpenAI (AI features) ---------------------------------------------------
# API key for @ai-sdk/openai. [SECRET]
OPENAI_API_KEY=
# Organization id. [SECRET, optional]
OPENAI_ORG_ID=
# Model name. [optional]
OPENAI_MODEL=gpt-4o

# --- Telegram (property notifications) --------------------------------------
# Bot token from @BotFather. [SECRET]
TELEGRAM_BOT_TOKEN=
# Enable/disable Telegram notifications ("true" to enable). [optional]
TELEGRAM_NOTIFICATIONS_ENABLED=false
# Default (Spanish) group chat id. [optional]
TELEGRAM_GROUP_DEFAULT=-1002750613848
# Optional US group chat id. [optional]
TELEGRAM_GROUP_US=

# --- Object storage (AWS S3) ------------------------------------------------
# Leave AWS_ENDPOINT_URL unset for native AWS S3 (production). Only set it for
# S3-compatible mocks (MinIO, localstack). [optional]
AWS_ENDPOINT_URL=
# Region of the bucket (production: us-west-2). [optional]
AWS_REGION=us-west-2
# Access key id. [SECRET]
AWS_ACCESS_KEY_ID=
# Secret access key. [SECRET]
AWS_SECRET_ACCESS_KEY=
# Bucket name for uploaded images (production: oxy-homiio-media-usw2-…). [optional]
AWS_S3_BUCKET=oxy-homiio-media-usw2-237343248947

# --- Stripe (billing / subscriptions) ---------------------------------------
# Secret API key (sk_live_... / sk_test_...). [SECRET]
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...). [SECRET]
STRIPE_WEBHOOK_SECRET=
# Price ids for the subscription tiers. [optional]
STRIPE_PRICE_PLUS=
STRIPE_PRICE_FILE=
# Override checkout redirect URLs (else derived from FRONTEND_URL). [optional]
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
# Public webhook URL used for self-registration tooling, if applicable. [optional]
STRIPE_WEBHOOK_URL=

# --- Redis (caching / sessions) ---------------------------------------------
# Connection URL. [optional]
REDIS_URL=redis://localhost:6379
# Default TTL in seconds. [optional]
REDIS_TTL=3600

# --- Email (transactional) --------------------------------------------------
# Nodemailer service name (e.g. gmail). [optional]
EMAIL_SERVICE=gmail
# SMTP account user. [SECRET, optional]
EMAIL_USER=
# SMTP account password / app password. [SECRET, optional]
EMAIL_PASSWORD=

# --- Logging ----------------------------------------------------------------
# Log level. [optional]
LOG_LEVEL=info
# Log file path. In containers, leave UNSET to log to stdout only; set to a
# writable mounted path to also write JSON file logs. [optional]
LOG_FILE=

# --- Geocoding (Nominatim / OpenStreetMap — free, no key) -------------------
# [optional]
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# OSM usage policy REQUIRES a descriptive, identifying User-Agent. [optional]
GEOCODING_USER_AGENT=Homiio/1.0 (+https://homiio.com)
GEOCODING_REFERER=https://homiio.com

# --- Overpass (OpenStreetMap POI lookup — free, no key) ---------------------
# [optional]
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_USER_AGENT=Homiio/1.0 (+https://homiio.com)

# --- Listing ingestion worker (@homiio/listing-providers on BullMQ) ---------
# External listing ingestion runs in the dedicated worker process
# (`bun run worker`), NOT on a cron in the API. It reuses REDIS_URL above for
# BullMQ; when REDIS_URL is unset the worker falls back to inline processing.
# Generic TTL (days) for externally-sourced listings. [optional]
EXTERNAL_PROPERTY_TTL_DAYS=30
# BullMQ key prefix (must NOT contain ':'). [optional]
LISTING_QUEUE_PREFIX=bull-homiio-listings
# Enqueue an initial discover pass on worker boot (default false). [optional]
LISTING_DISCOVER_ON_BOOT=false
# Fetch-worker concurrency (source portals are rate-sensitive). [optional]
LISTING_FETCH_CONCURRENCY=2
# Comma-separated ES cities the Spanish portals (idealista/fotocasa) discover in.
# Unset → each provider falls back to its own default city list. [optional]
LISTING_ES_CITIES=madrid,barcelona,valencia

# --- Fetch escalation tiers (WORKER ONLY — the API never scrapes) -----------
# The shared fetch ladder is HTTP → browser → managed. Both escalation rungs are
# OFF by default; a rung the worker did not provision is simply skipped.
#
# Browser tier (Playwright, headless Chromium). Playwright is an OPTIONAL peer of
# @homiio/listing-providers — install it in the worker image to enable this:
#   bun add -D playwright && bunx playwright install --with-deps chromium
# When "true" but Playwright is NOT installed, the tier is skipped (logged), so
# CI/hosts without a browser keep working. [optional]
LISTING_BROWSER_ENABLED=false
# Max concurrent headless contexts (a browser is memory-heavy — keep small). [optional]
LISTING_BROWSER_MAX_CONCURRENCY=2
# Hard per-navigation timeout in ms. [optional]
LISTING_BROWSER_TIMEOUT_MS=90000
# Block images/CSS/fonts in Playwright to keep residential-proxy bandwidth cheap.
# Unset or "true" (default) = ON; set "false" to load all assets. [optional]
LISTING_BROWSER_BLOCK_ASSETS=true
#
# DIY residential proxy for anti-bot bypass (Homiio's own worker scrapes — NOT a
# scraping API). Format: http://LOGIN:PASSWORD@HOST:PORT
# DataImpulse example (sticky session suffix documented below):
#   http://YOUR_LOGIN:YOUR_PASSWORD@gw.dataimpulse.com:823
# Leave UNSET in prod until credentials are in SSM — code ships ready, proxy OFF. [SECRET, optional]
LISTING_RESIDENTIAL_PROXY_URL=
# Route plain HTTP listing fetches through the residential proxy (HTML/JSON only).
# Requires LISTING_RESIDENTIAL_PROXY_URL. Default OFF. [optional]
LISTING_HTTP_USE_PROXY=false
# Sticky exit IP: append -session-<id> to the proxy username per browser context /
# HTTP session (DataImpulse: login-session-abc123 in the username field). [optional]
LISTING_PROXY_STICKY=false
# On image ingest failure, retry once via residential proxy. Photos default to direct
# fetch (cheap); enable only if portal CDNs block datacenter IPs. [optional]
LISTING_MEDIA_PROXY_FALLBACK=false
#
# Managed tier (residential-proxy / anti-bot fetch service, e.g. ScraperAPI,
# ScrapingBee, Zyte). Enabled ONLY when LISTING_MANAGED_FETCH_URL is set; unset =
# the managed rung does not exist (never faked). The target URL is passed as the
# `LISTING_MANAGED_FETCH_URL_PARAM` query param (default `url`); the key is sent
# as the `LISTING_MANAGED_FETCH_KEY_HEADER` header (default `X-Api-Key`), OR as a
# query param when LISTING_MANAGED_FETCH_KEY_PARAM is set instead.
LISTING_MANAGED_FETCH_URL=
# API key for the managed service. [SECRET, optional]
LISTING_MANAGED_FETCH_KEY=
# Query param the target URL is passed in. [optional]
LISTING_MANAGED_FETCH_URL_PARAM=url
# Header the API key is sent in (ignored when LISTING_MANAGED_FETCH_KEY_PARAM set). [optional]
LISTING_MANAGED_FETCH_KEY_HEADER=X-Api-Key
# When set, send the key as this query param instead of a header. [optional]
LISTING_MANAGED_FETCH_KEY_PARAM=
# Hard per-request timeout in ms for managed fetches. [optional]
LISTING_MANAGED_FETCH_TIMEOUT_MS=60000

# --- Listing provider feature flags -----------------------------------------
# Per-portal ingest toggles, read as `PROVIDER_<ID>_ENABLED`. Each defaults OFF;
# a portal only discovers/ingests when its flag is exactly "true". The Phase-0
# `fixture` provider is always on (it never touches a real portal). [optional]
PROVIDER_HABITACLIA_ENABLED=false
PROVIDER_BLUEGROUND_ENABLED=false
# ES market (idealista + fotocasa). Anti-bot heavy — keep OFF until the browser/
# managed escalation tiers are provisioned (see services/ingestion). [optional]
PROVIDER_IDEALISTA_ENABLED=false
PROVIDER_FOTOCASA_ENABLED=false
# US market (apartments.com + Zillow). [optional]
PROVIDER_APARTMENTS_COM_ENABLED=false
PROVIDER_ZILLOW_ENABLED=false

# --- Admin gate -------------------------------------------------------------
# Comma-separated Oxy user ids allowed to call privileged endpoints
# (`/api/scraper/*`). Empty = nobody (routes locked until set). [optional]
HOMIIO_ADMIN_OXY_USER_IDS=

# --- Platform-injected (do NOT set manually) --------------------------------
# These are set automatically by serverless platforms and only READ by the app
# to toggle serverless behavior. Leave unset on AWS ECS/EC2 (Graviton):
#   VERCEL, AWS_LAMBDA_FUNCTION_NAME, FUNCTION_TARGET
