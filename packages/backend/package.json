{
  "name": "@homiio/backend",
  "version": "1.0.0",
  "description": "Enhanced Homiio Backend with Device-Based Authentication",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "server.ts",
  "scripts": {
    "start": "ts-node --transpile-only server.ts",
    "dev": "nodemon --watch \"**/*.ts\" --exec ts-node --transpile-only server.ts",
    "worker": "ts-node --transpile-only worker.ts",
    "dev:worker": "nodemon --watch \"**/*.ts\" --exec ts-node --transpile-only worker.ts",
    "build": "tsc",
    "migrate:billing": "node scripts/migrate-billing-field.js",
    "migrate:city-geo": "ts-node --transpile-only scripts/migrate-city-geo.ts",
    "seed:geo": "ts-node --transpile-only scripts/seedGeo.ts",
    "seed:properties": "ts-node --transpile-only scripts/seedProperties.ts",
    "test": "cd ../listing-providers && bun run build && cd ../backend && NODE_OPTIONS='--max-old-space-size=6144' jest",
    "test:watch": "jest --watch",
    "test:images": "ts-node --transpile-only scripts/test-image-upload.ts",
    "test:webhook": "node scripts/test-stripe-webhook.js",
    "test:subscription-save": "node scripts/test-subscription-save.js",
    "check:subscriptions": "node scripts/check-subscription-db.js",
    "cleanup:external-profile-id": "ts-node --transpile-only scripts/cleanup-external-profileId.ts",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts",
    "backfill:price-ethics": "ts-node --transpile-only scripts/backfillPriceEthics.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "@homiio/listing-providers": "workspace:*",
    "@homiio/shared-types": "workspace:*",
    "@oxyhq/core": "^9.0.0",
    "ai": "^4.3.16",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.3",
    "bullmq": "^5.79.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "i18n": "^0.15.3",
    "mongoose": "^8.18.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-parse": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "stripe": "^16.11.0",
    "telegraf": "^4.16.3",
    "uuid": "^11.0.0",
    "validator": "^13.15.35",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/i18n": "^0.13.12",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^9.39.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "node-fetch": "^2.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
