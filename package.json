{
    "name": "homiio-monorepo",
    "version": "2.0.0",
    "description": "Homiio Monorepo - Frontend and Backend",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "bun run dev --filter '*'",
        "dev:frontend": "bun run --filter @homiio/frontend dev",
        "dev:backend": "bun run --filter @homiio/backend dev",
        "build": "bun run --filter '*' build",
        "build:shared-types": "bun run --filter @homiio/shared-types build",
        "build:frontend": "bun run --filter @homiio/frontend build",
        "build:backend": "bun run --filter @homiio/backend build",
        "test": "bun run --filter '*' test",
        "lint": "bun run --filter '*' lint",
        "clean": "bun run --filter '*' clean && rm -rf node_modules",
        "install:all": "bun install",
        "start:frontend": "bun run --filter @homiio/frontend start",
        "start:backend": "bun run --filter @homiio/backend start",
        "postinstall": "bun run build:shared-types"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "ajv": "^8.17.1",
        "ajv-keywords": "^5.1.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "tailwindcss": "^3.4.17",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": "22.x"
    },
    "overrides": {
        "@oxyhq/core": "2.3.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "@react-native-async-storage/async-storage": "2.2.0",
        "react-native-reanimated": "4.3.1",
        "react-native-worklets": "0.8.3",
        "react-native-svg": "15.15.4"
    },
    "cacheDirectories": []
}
